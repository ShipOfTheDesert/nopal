# Custom files
**/*.env

# Ocaml standard
*.annot
*.cmo
*.cma
*.cmi
*.a
*.o
*.cmx
*.cmxs
*.cmxa

# Files containing detailed information about the compilation (generated
# by `ocamlc`/`ocamlopt` when invoked using the option `-bin-annot`).
# These files are typically useful for code inspection tools
# (e.g. Merlin).
*.cmt
*.cmti

# ocamlbuild and Dune default working directory
_build/

# ocamlbuild targets
*.byte
*.native

# oasis generated files
setup.data
setup.log

# Merlin configuring file for Vim and Emacs
.merlin

# Dune generated files
*.install

# Local OPAM switch
_opam/
_opam

# Test artifacts
test-results/
test/e2e/node_modules/
test/e2e/tauri/node_modules/
test/e2e/playwright-report/
test/e2e/test-results/
test/e2e/.cache/

# Bench artifacts
bench/results.json
bench/runner/results/
bench/runner/node_modules/
bench/runner/test-results/

# Site build output
dist/

# Tauri
tauri/dist/
tauri/node_modules/
tauri/src-tauri/target/
tauri/src-tauri/gen/

# The Android project under gen/ is generated by `tauri android init` and stays
# ignored — except MainActivity.kt, which carries the hand-written native
# safe-area / soft-keyboard bridge (RFC 0116). Re-include just that file by
# un-ignoring each ancestor directory down to it. If `tauri android init` is
# re-run on a fresh checkout, re-apply this file from version control.
!tauri/src-tauri/gen/
tauri/src-tauri/gen/*
!tauri/src-tauri/gen/android/
tauri/src-tauri/gen/android/*
!tauri/src-tauri/gen/android/app/
tauri/src-tauri/gen/android/app/*
!tauri/src-tauri/gen/android/app/src/
tauri/src-tauri/gen/android/app/src/*
!tauri/src-tauri/gen/android/app/src/main/
tauri/src-tauri/gen/android/app/src/main/*
!tauri/src-tauri/gen/android/app/src/main/java/
tauri/src-tauri/gen/android/app/src/main/java/*
!tauri/src-tauri/gen/android/app/src/main/java/run/
tauri/src-tauri/gen/android/app/src/main/java/run/*
!tauri/src-tauri/gen/android/app/src/main/java/run/nopal/
tauri/src-tauri/gen/android/app/src/main/java/run/nopal/*
!tauri/src-tauri/gen/android/app/src/main/java/run/nopal/kitchen_sink/
tauri/src-tauri/gen/android/app/src/main/java/run/nopal/kitchen_sink/*
!tauri/src-tauri/gen/android/app/src/main/java/run/nopal/kitchen_sink/MainActivity.kt
