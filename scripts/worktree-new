#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git -C "$(dirname "$0")/.." rev-parse --show-toplevel)"

usage() {
  echo "Usage: $(basename "$0") <branch-name>" >&2
  exit 1
}

[[ $# -eq 1 ]] || usage

BRANCH="$1"
WORKTREE_DIR="${REPO_ROOT}/../nopal-${BRANCH}"

if [[ -d "$WORKTREE_DIR" ]]; then
  echo "Error: worktree directory already exists: ${WORKTREE_DIR}" >&2
  exit 1
fi

echo "Creating worktree at ${WORKTREE_DIR} on branch ${BRANCH}..."
git -C "$REPO_ROOT" worktree add -b "$BRANCH" "$WORKTREE_DIR"

# Files and directories listed in .git/info/exclude that are needed for work.
# .cursor/ and .vscode/ are editor configs — included so IDE settings carry over.
IGNORED_ITEMS=(
    claude_code_workflow_template.md
    CLAUDE.md
    docs/
    tasks/
    quality_reports/
    memory/
    .cursor/
    .vscode/
    .claude/
    planning/
    .env
)

echo "Copying ignored files..."
for item in "${IGNORED_ITEMS[@]}"; do
  src="${REPO_ROOT}/${item}"
  if [[ -e "$src" ]]; then
    if [[ -d "$src" ]]; then
      cp -r "$src" "${WORKTREE_DIR}/${item}"
    else
      cp "$src" "${WORKTREE_DIR}/${item}"
    fi
    echo "  copied ${item}"
  fi
done

echo ""
echo "Done. Worktree ready at: ${WORKTREE_DIR}"
echo "  cd ${WORKTREE_DIR}"
